{
  "extends": "./node_modules/astro/tsconfigs/strict.json",
  "compilerOptions": {
    "baseUrl": ".",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "types": ["@cloudflare/workers-types", "./worker-configuration.d.ts", "node"],
    "paths": {
      "@/*": ["src/frontend/*", "src/backend/*"],
      "@/backend/*": ["src/backend/*"],
      "@/backend/db/*": ["src/backend/db/*"]
    }
  },
  "include": ["src/**/*", "worker-configuration.d.ts"]
}
